<!DOCTYPE html>
<html lang="en">

<head>
    {{>meta}}
    <title>Sign Up</title>
</head>

<body class="text-center">

    <div class="container text-center my-5">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-body">
                        <div class="card-image"><img src="../img/ic_launcher.png" alt="" srcset=""></div>
                        <h1 class="card-title">Signup Page</h1>
                        <form action="/signup" class="loginLocal needs-validation" method="POST" novalidate>
                            <div class="mb-3">
                                <label for="username" class="form-label">Username</label>
                                <input type="text" class="form-control" name="username" id="username"
                                    placeholder="Enter Username" autocomplete="username" required>
                                <div class="invalid-feedback">
                                    Please enter a username.
                                </div>
                            </div>
                            <div class="mb-3">
                                <label for="password" class="form-label">Password</label>
                                <input type="password" class="form-control" name="password" id="password"
                                    placeholder="Enter Password" autocomplete="new-password" required>
                                <div class="invalid-feedback">
                                    Please enter a password.
                                </div>
                            </div>
                            <button type="submit" class="btn btn-primary">Signup</button>
                             <a href="/login" class="btn btn-outline-secondary">Login</a>
                        </form>
                    </div>
                </div>
            </div>

    <script src="/js/formValidation.js"></script>
</body>

</html>