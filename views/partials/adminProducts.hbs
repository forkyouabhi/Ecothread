<div class="row row-cols-1 row-cols-md-3 g-4">
  {{#each this.products as |product|}}
  <div class="col">
    <div class="card">
      <img src="{{product.imageUrl}}" class="card-img-top" alt="{{product.name}}" width="30%">
      <div class="card-body">
        <h5 class="card-title">{{product.name}}</h5>
        <p class="card-text">{{product.description}}</p>
      </div>
       <div class="card-footer d-flex gap-2 justify-content-center flex-wrap">
        {{!-- <small class="price">$ <bold>{{product.price}}</bold> </small> --}}
        <button type="button" class="btn btn-outline-danger" aria-label="Delete {{product.name}}">Delete</button>
        <button type="button" class="btn btn-outline-secondary" aria-label="Update {{product.name}}">Update</button>
        <button type="button" class="btn btn-primary" aria-label="Details for {{product.name}}">Details</button>
      </div>
    </div>
  </div>
  {{else}}
  <div class="col-12 text-center py-5">
    <div class="mb-3">
      <span style="font-size: 3rem;" aria-hidden="true">📦</span>
    </div>
    <h4>No listings yet</h4>
    <p class="text-muted mb-4">You haven't added any products to your store.</p>
    <a href="/admin/add-product" class="btn btn-primary">List your first product</a>
    <div class="card shadow-sm border-0">
      <div class="card-body py-5">
        <h4 class="card-title mb-3">No products yet</h4>
        <p class="card-text text-muted mb-4">Start building your catalog by listing your first product.</p>
        <a href="/admin/add-product" class="btn btn-primary btn-lg" aria-label="List a new product">List a Product</a>
      </div>
    </div>
  </div>
  {{else}}
  <div class="col-12 text-center py-5 w-100">
    <div class="text-muted mb-3">
      <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" fill="currentColor" class="bi bi-box-seam" viewBox="0 0 16 16" aria-hidden="true">
        <path d="M8.186 1.113a.5.5 0 0 0-.372 0L1.846 3.5l2.404.961L10.404 2l-2.218-.887zm3.564 1.426L5.596 5 8 5.961 14.154 3.5l-2.404-.961zm3.25 1.7-6.5 2.6v7.922l6.5-2.6V4.24zM7.5 14.762V6.84l-6.5-2.6v7.922l6.5 2.6zM5.22 4.243l-2.404-.961L8 1.113l2.404.961L5.22 4.243z"/>
      </svg>
    </div>
    <h4>No products listed yet</h4>
    <p class="text-muted mb-4">You haven't listed any products yet. Let's get started!</p>
    <a href="/admin/add-product" class="btn btn-primary">List Your First Product</a>
  </div>
  {{/each}}
</div>
